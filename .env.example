# =============================================================
# Frontend Environment Variables - Example
# Copy this file to .env and fill in your actual values
# =============================================================

# -------------------------------------------------------------
# 1. رابط الـ API الخاص بالباك إند (يجب أن يحتوي على https:// ومسار /api)
# IMPORTANT: Must include the protocol (https://) and /api at the end
# Example for production: https://api.klevro.tech/api
# Example for local dev:  http://localhost:5000/api
# -------------------------------------------------------------
NEXT_PUBLIC_API_URL="https://api.your-domain.com/api"

# -------------------------------------------------------------
# 2. رابط الباك إند الأساسي (بدون /api في النهاية)
# Used by next.config.ts to proxy API requests server-side (avoids CORS)
# Must include the protocol (https://)
# Example for production: https://api.klevro.tech
# Example for local dev:  http://localhost:5000
# -------------------------------------------------------------
BACKEND_ORIGIN="https://api.your-domain.com"

# -------------------------------------------------------------
# 3. منفذ تشغيل تطبيق Next.js
# -------------------------------------------------------------
PORT=3000
NODE_ENV="production"
